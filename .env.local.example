# Admin URL — used by migrations to create roles
DATABASE_URL_ADMIN=postgres://postgres:devpassword@localhost:5432/launcher

# App URLs — used by the running app
DATABASE_URL=postgres://app_writer:app_writer_dev_pwd@localhost:5432/launcher
DATABASE_URL_READ=postgres://app_reader:app_reader_dev_pwd@localhost:5432/launcher
TEST_DATABASE_URL=postgres://postgres:devpassword@localhost:5432/launcher_test

# Passwords used by migration 001 to create roles
APP_READER_PWD=app_reader_dev_pwd
APP_WRITER_PWD=app_writer_dev_pwd
N8N_WRITER_PWD=n8n_writer_dev_pwd

# n8n webhook for todo sync
N8N_TODO_WEBHOOK_URL=https://n8n.example.com/webhook/todo-sync
N8N_TODO_WEBHOOK_TOKEN=change_me_in_prod

# Whoogle URL + launcher tile URLs are now configurable at runtime via /config
# (stored in app_config and launcher_tiles tables). The launcher will auto-seed
# 11 default tiles with href='#' on first request; Whoogle URL empty → Google fallback.

# Personal display (optional). Empty → "Bonjour" + "Météo · —".
NEXT_PUBLIC_USER_NAME=
NEXT_PUBLIC_WEATHER_LOCATION=

LOG_LEVEL=info

# Where user-uploaded background images are stored.
# Dev: relative path to a local dir. Prod: Docker volume at /app/data/uploads.
UPLOAD_DIR=./data/uploads
