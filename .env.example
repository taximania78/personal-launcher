# === Postgres ===
PG_ADMIN_PWD=change_me

# === App roles ===
APP_READER_PWD=change_me
APP_WRITER_PWD=change_me
N8N_WRITER_PWD=change_me

# === n8n webhook ===
N8N_TODO_WEBHOOK_URL=https://n8n.example.com/webhook/todo-sync
N8N_TODO_WEBHOOK_TOKEN=change_me

# Whoogle URL + launcher tile URLs are now configurable at runtime via /config
# (stored in app_config and launcher_tiles tables). The launcher will auto-seed
# 11 default tiles with href='#' on first request; Whoogle URL empty → Google fallback.

# Personal display (optional). Empty → "Bonjour" + "Météo · —".
NEXT_PUBLIC_USER_NAME=
NEXT_PUBLIC_WEATHER_LOCATION=

LOG_LEVEL=info
